# ── RFP Intelligence Copilot — environment variables ─────────────────────────
#
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=<your-jwt-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage backend ──────────────────────────────────────────────────────────
# Options: "local" (default) or "gcs"
# local: files are stored in ./projects/ on the server filesystem
# gcs:   files are stored in Google Cloud Storage (recommended for production)
STORAGE_BACKEND=local

# ── Google Cloud Storage (required when STORAGE_BACKEND=gcs) ──────────────
#
# The name of your GCS bucket. Must exist before starting the server.
# Example: my-company-rfp-store
GCS_BUCKET_NAME=procureiq-rfp-store
#
# Path to a GCP service account JSON key file.
# The service account needs roles: Storage Object Admin on the bucket.
# Example: /secrets/gcp-sa-key.json
# Leave blank if running on GCP (Cloud Run / GKE) with Workload Identity —
# the SDK will pick up credentials from the metadata server automatically.
GOOGLE_APPLICATION_CREDENTIALS=
#
# GCP Project ID (optional — needed only if the SDK can't infer it).
GOOGLE_CLOUD_PROJECT=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email (optional — for communications module) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
SMTP_FROM=<your-email@gmail.com>
