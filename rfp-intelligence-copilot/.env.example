# ── RFP Intelligence Copilot — environment variables ─────────────────────────
#
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=<your-jwt-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage backend ──────────────────────────────────────────────────────────
# Options: "local" | "gcs" | "s3" | "r2"
#
#  local  — writes files to LOCAL_STORAGE_PATH on the container filesystem.
#            Ephemeral on HF Spaces (data lost on restart). Dev only.
#
#  gcs    — Google Cloud Storage. Recommended for production / HF Spaces.
#            Files survive container restarts with zero extra config.
#            Requires GCS_BUCKET_NAME + GCS_CREDENTIALS_JSON (see below).
STORAGE_BACKEND=gcs

# ── Local filesystem (dev only) ────────────────────────────────────────────
LOCAL_STORAGE_PATH=./uploads

# ── Google Cloud Storage (required when STORAGE_BACKEND=gcs) ──────────────
#
# Your GCS bucket name.
GCS_BUCKET_NAME=<your-gcs-bucket-name>
#
# Service account credentials as a JSON string.
# On HF Spaces: add this as a Space secret named GCS_CREDENTIALS_JSON.
# Locally: paste the JSON inline, or load from a file:
#   export GCS_CREDENTIALS_JSON=$(cat /path/to/sa-key.json)
# Leave blank to use Application Default Credentials (ADC) / Workload Identity.
GCS_CREDENTIALS_JSON=<paste-service-account-json-here>

# ── AWS S3 (required when STORAGE_BACKEND=s3) ─────────────────────────────
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_REGION=us-east-1
S3_BUCKET_NAME=<your-s3-bucket-name>

# ── Cloudflare R2 (required when STORAGE_BACKEND=r2) ─────────────────────
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=<your-r2-bucket-name>

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email (optional — for communications module) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
SMTP_FROM=<your-email@gmail.com>
