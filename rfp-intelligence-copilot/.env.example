# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM ──────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ── Auth ─────────────────────────────────────────
# Any random 32+ character string. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<random-secret-key>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────
# Leave blank to use SQLite (fine for dev / HF Spaces free tier)
# For production use a PostgreSQL URL:
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>
DATABASE_URL=

# ── Email (SMTP) ──────────────────────────────────
# All optional — if unset, emails are drafted but not sent
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
# For Gmail, use an App Password (not your main password):
# https://myaccount.google.com/apppasswords
SMTP_PASSWORD=<your-smtp-app-password>
SMTP_FROM=<your-email@gmail.com>

# ── CORS ──────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://sourceiq.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
